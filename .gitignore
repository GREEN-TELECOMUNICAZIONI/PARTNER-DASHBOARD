# ============================================
# TWT Partner Dashboard - .gitignore
# ============================================

# Environment files (IMPORTANT: NEVER commit secrets!)
.env
.env.local
.env.production
.env.development
*.env
!.env.example
!.env.portainer.example
!backend/.env.example
!frontend/.env.example

# Logs
.logs/
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# PID files
.pids/
*.pid
*.seed
*.pid.lock

# Dependency directories
node_modules/
jspm_packages/

# Build outputs
dist/
dist-ssr/
build/
# NOTE: NOT ignoring 'coverage' to allow src/components/coverage directory
*.local

# Cache directories
.npm
.eslintcache
.stylelintcache
.vite/
.cache/

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*~

# IDE files
.vscode/
.idea/
*.swp
*.swo
*.swn
.project
.classpath
.settings/
*.sublime-workspace
*.sublime-project

# Docker
docker-compose.override.yml

# Test coverage
# NOTE: Using specific paths to not block src/components/coverage
**/coverage/
!**/src/components/coverage/
*.lcov
.nyc_output/

# Temporary files
*.tmp
*.temp
temp/
tmp/

# Backup files
*.backup
*.bak
*.old

# Documentation builds
docs/_build/
site/
