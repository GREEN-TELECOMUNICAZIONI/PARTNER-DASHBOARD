# Server Configuration
NODE_ENV=development
PORT=3000

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# TWT API Configuration
TWT_API_BASE_URL=https://reseller.twt.it/api/xdsl
TWT_API_USERNAME=your_username_here
TWT_API_PASSWORD=your_password_here

# Provider filter for coverage services (comma-separated IDs)
# Common provider IDs:
# 10 = TIM
# 20 = Fastweb
# 30 = Altri operatori
# 160 = FWA EW
#
# Examples:
# TWT_PROVIDER_FILTER=10          # Only TIM
# TWT_PROVIDER_FILTER=10,20       # TIM and Fastweb
# TWT_PROVIDER_FILTER=             # All providers (no filter)
TWT_PROVIDER_FILTER=10

# Technology filter for coverage services (comma-separated)
# Filters services by technology type in ServiceName
# Available values: FTTC, FTTH, ETH (case-insensitive)
#
# Examples:
# TWT_TECHNOLOGY_FILTER=FTTC,FTTH  # Only FTTC and FTTH services
# TWT_TECHNOLOGY_FILTER=FTTH       # Only FTTH services
# TWT_TECHNOLOGY_FILTER=ETH        # Only ETH services
# TWT_TECHNOLOGY_FILTER=           # All technologies (no filter)
TWT_TECHNOLOGY_FILTER=FTTC,FTTH

# Include ONLY these service variants (comma-separated keywords in ServiceName)
# Available variants: Lite, VULA, EVDSL, Asimmetrica, Simmetrica, Dedicata
# If set, ONLY services containing at least one of these keywords will be shown
# Leave empty to include all variants (default behavior)
# Case-sensitive matching
#
# Examples:
# TWT_INCLUDE_VARIANTS=EVDSL           # Only "FTTCab EVDSL"
# TWT_INCLUDE_VARIANTS=EVDSL,VULA      # Only services with EVDSL or VULA in name
# TWT_INCLUDE_VARIANTS=Simmetrica      # Only "ETH Simmetrica"
# TWT_INCLUDE_VARIANTS=                # All variants allowed (default)
TWT_INCLUDE_VARIANTS=

# Exclude service variants (comma-separated keywords in ServiceName)
# Available variants: Lite, VULA, EVDSL, Asimmetrica, Simmetrica, Dedicata
# If set, services containing these keywords will be excluded
# Leave empty to not exclude any variants
# Case-sensitive matching
#
# Examples:
# TWT_EXCLUDE_VARIANTS=Lite            # Exclude "FTTH Lite", "FTTCab Lite"
# TWT_EXCLUDE_VARIANTS=Lite,VULA       # Exclude Lite and VULA variants
# TWT_EXCLUDE_VARIANTS=Dedicata        # Exclude "Fibra Dedicata"
# TWT_EXCLUDE_VARIANTS=                # No exclusions
#
# NOTE: EXCLUDE has priority over INCLUDE
# If a service matches both INCLUDE and EXCLUDE, it will be excluded
TWT_EXCLUDE_VARIANTS=Lite

# Exclude speed profiles with specific priority values (comma-separated)
# Profiles from GetListino API with these priority values will be excluded
# Common values: 9999 = deprecated/inactive profiles
#
# Examples:
# EXCLUDE_PROFILES_WITH_PRIORITY=9999  # Exclude deprecated profiles
# EXCLUDE_PROFILES_WITH_PRIORITY=9999,8888  # Exclude multiple priority values
# EXCLUDE_PROFILES_WITH_PRIORITY=      # Include all profiles (no filter)
EXCLUDE_PROFILES_WITH_PRIORITY=9999
