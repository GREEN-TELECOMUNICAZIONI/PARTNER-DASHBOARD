# ============================================
# Environment Variables per Portainer Stack
# ============================================
#
# Questo file serve come riferimento per le variabili
# da configurare in Portainer UI.
#
# In Portainer: Stacks → twt-partner-dashboard → Editor
# Sezione "Environment variables"
# ============================================

# Docker Hub Configuration
DOCKER_USERNAME=your-dockerhub-username

# Server Configuration
CORS_ORIGIN=http://your-server-ip

# TWT API Credentials
TWT_API_USERNAME=GREENTEL_PAVONE
TWT_API_PASSWORD=Pc_260516

# TWT API Configuration (optional - hanno default)
TWT_API_TIMEOUT=30000
TWT_API_MAX_RETRIES=3

# Rate Limiting (optional - hanno default)
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# Provider Filters
TWT_PROVIDER_FILTER=10
TWT_TECHNOLOGY_FILTER=FTTC,FTTH
TWT_INCLUDE_VARIANTS=
TWT_EXCLUDE_VARIANTS=Lite

# Profile Filters
EXCLUDE_PROFILES_WITH_PRIORITY=9999
PROFILE_DESCRIPTION_PREFIX=TWT_TI
EXCLUDE_PROFILES_BY_KEYWORD=
PROFILE_TABLE_COLUMNS=description
